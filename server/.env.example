# Required. Leave empty until you set a long random value.
WHISKER_AUTH_TOKEN=
WHISKER_SERVER_NAME=whisker-server
WHISKER_BIND_HOST=127.0.0.1
WHISKER_PORT=8787

# Request limits
WHISKER_MAX_UPLOAD_BYTES=52428800
WHISKER_MAX_DURATION_SECONDS=120
WHISKER_REQUEST_TIMEOUT_SECONDS=300
WHISKER_WORK_DIR=~/Library/Caches/WhiskerRemote

# Audio tools
WHISKER_FFMPEG=ffmpeg
WHISKER_FFPROBE=ffprobe

# ASR engine and model profiles
WHISKER_ENGINE=parakeet_mlx
WHISKER_FAST_MODEL=mlx-community/parakeet-tdt_ctc-110m
WHISKER_PARAKEET_MODEL=mlx-community/parakeet-tdt-0.6b-v3
WHISKER_BEST_MODEL=mlx-community/parakeet-tdt-1.1b
WHISKER_DEFAULT_MODEL_ID=balanced

# Optional cache override for downloaded Parakeet models
# WHISKER_PARAKEET_CACHE_DIR=~/Library/Caches/WhiskerRemote/parakeet

# Optional whisper.cpp comparison adapter
# WHISKER_ENGINE=whisper_cpp
# WHISKER_WHISPER_CLI=whisper-cli
# WHISKER_WHISPER_MODEL=~/Library/Application Support/WhiskerRemote/models/ggml-base.en.bin
# WHISKER_WHISPER_ARGS=--no-timestamps --language en

WHISKER_DEBUG=false
